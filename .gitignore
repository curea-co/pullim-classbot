# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (모노레포 — 모든 워크스페이스 node_modules 무시)
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# turbo
.turbo

# nest build
apps/backend/dist

# swc
.swc

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# playwright (모노레포 — 루트 + 앱별 산출물 모두 ignore)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
apps/*/test-results/
apps/*/playwright-report/
apps/*/blob-report/
apps/*/playwright/.cache/

# daily outcome (PM 개인 업무 보고)
/daily_outcome/

# Playwright 라이브 캡처 — 시각 검증 산출물, repo에 push 안 함
/output/live-shots/
/output/screen-captures/
apps/*/output/live-shots/
apps/*/output/screen-captures/

# 로컬 Postgres 컨테이너 볼륨 (docker-compose.yml)
/.docker/

# Playwright-MCP debug artifacts
.playwright-mcp/
