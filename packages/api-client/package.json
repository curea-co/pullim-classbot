{
  "name": "@pullim-classbot/api-client",
  "version": "0.0.1",
  "private": true,
  "description": "FE에서 classbot BE(/api/auth/*) 호출용 fetch 래퍼 + 토큰 매니저.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./token-manager": {
      "types": "./src/token-manager.ts",
      "default": "./src/token-manager.ts"
    },
    "./auth-api": {
      "types": "./src/auth-api.ts",
      "default": "./src/auth-api.ts"
    },
    "./jwt": {
      "types": "./src/jwt.ts",
      "default": "./src/jwt.ts"
    },
    "./jwt-verify": {
      "types": "./src/jwt-verify.ts",
      "default": "./src/jwt-verify.ts"
    }
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pullim-classbot/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
