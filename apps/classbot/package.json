{
  "name": "@pullim-classbot/classbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:3032 | xargs -r kill -9 2>/dev/null || true",
    "dev": "next dev -p 3032",
    "build": "next build",
    "start": "next start -p 3032",
    "lint": "eslint && node scripts/check-design-gates.mjs",
    "gates": "node scripts/check-design-gates.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "db:up": "docker compose -f ../../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../../docker-compose.yml down",
    "db:reset": "docker compose -f ../../docker-compose.yml down -v && rm -rf ../../.docker/postgres && docker compose -f ../../docker-compose.yml up -d postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@pullim-classbot/api-client": "workspace:*",
    "@pullim-classbot/auth": "workspace:*",
    "@pullim-classbot/types": "workspace:*",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "katex": "^0.16.45",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-katex": "^3.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
