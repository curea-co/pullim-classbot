# 풀림 클래스봇 백엔드 (NestJS, port 4032) 환경변수 예시
# 실제 값은 .env 또는 .env.local 에 두고 커밋하지 않는다(.gitignore: .env*).

# --- 서버 ---
PORT=4032
# 브라우저 CORS 허용 오리진(콤마 구분). 기본 classbot FE dev(:3032).
CORS_ORIGIN=http://localhost:3032

# --- 데이터베이스 (docker-compose postgres, 호스트 5434 노출) ---
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USERNAME=pullim
DATABASE_PASSWORD=pullim
DATABASE_NAME=pullim_classbot

# --- JWT ---
# JWT_SECRET 은 충분히 긴 랜덤 문자열로 교체할 것 (운영 시 비밀로 관리).
JWT_SECRET=change-me-to-a-long-random-secret
# Access Token 만료(초) — 기본 3600(1시간)
JWT_EXPIRATION=3600
# Refresh Token 만료(초) — 기본 1209600(14일)
JWT_REFRESH_EXPIRATION=1209600

# --- 비밀번호 해시 ---
# bcrypt 앞단 HMAC pepper(서버 비밀키). DB 유출 시에도 역산 난이도를 높인다.
PASSWORD_PEPPER=change-me-to-a-long-random-pepper

# --- QGen AI (재응시 문항 생성) ---
# 기능 활성화 여부 (true/false, 기본값 false).
QGEN_ENABLED=false
# QGen 엔드포인트 base URL (미사용 시 공란 가능).
QGEN_BASE_URL=
# QGen API 인증 키 (미사용 시 공란 가능).
QGEN_API_KEY=
# 데모 좌표 — taskFamilyId (UUID).
QGEN_DEMO_TASK_FAMILY_ID=
# 데모 좌표 — subjectId (UUID).
QGEN_DEMO_SUBJECT_ID=
# 데모 좌표 — gradeId (UUID).
QGEN_DEMO_GRADE_ID=
# 데모 좌표 — achievementStandardId (UUID).
QGEN_DEMO_ACHIEVEMENT_STANDARD_ID=
# 데모 좌표 — sourceId (UUID).
QGEN_DEMO_SOURCE_ID=
