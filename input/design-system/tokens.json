{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$meta": {
    "name": "@pullim/design-tokens",
    "version": "0.1.0",
    "summary": "Pullim 통합 디자인 토큰 — Planner/Q/Classbot 공용",
    "extractedFrom": [
      "https://pullim-planner.vercel.app/planner",
      "https://pullim-q.vercel.app/q",
      "https://pullim-classbot.vercel.app/classbot"
    ],
    "auditedAt": "2026-05-19"
  },
  "color": {
    "brand": {
      "50":  { "value": "#EEF3FF" },
      "100": { "value": "#DCE6FF" },
      "200": { "value": "#B8CDFF" },
      "300": { "value": "#8BAEFF" },
      "400": { "value": "#5A8BFF" },
      "500": { "value": "#3B6FF6" },
      "600": { "value": "#2854D8", "description": "★ Primary CTA. 세 앱 공통 브랜드 컬러." },
      "700": { "value": "#1D3FA8", "description": "Hover / pressed." },
      "900": { "value": "#070F2C" }
    },
    "accent": {
      "lime":     { "value": "#E6FF4C" },
      "lime-on":  { "value": "#5C6B0A", "description": "라임 위 텍스트 (AAA 통과)." }
    },
    "text": {
      "primary":     { "value": "#121627" },
      "secondary":   { "value": "#4A536A" },
      "tertiary":    { "value": "#6B7489", "description": "★ 본문 메타 최소선. 12~14px 텍스트는 여기까지." },
      "quaternary":  { "value": "#97A0B4", "description": "14px 이상에서만 사용 (대비 ~3.0:1)." },
      "disabled":    { "value": "#B7BDCD" },
      "on-primary":  { "value": "#FFFFFF" }
    },
    "surface": {
      "canvas":   { "value": "#F5F7FB", "description": "페이지 배경." },
      "subtle":   { "value": "#EDF0F5" },
      "default":  { "value": "#FFFFFF" },
      "inverse":  { "value": "#0F1A3A", "description": "LIVE/리플레이 등 강조 카드용." }
    },
    "border": {
      "subtle":  { "value": "#EDF0F5" },
      "default": { "value": "#DDE2EC" },
      "strong":  { "value": "#B7BDCD" }
    },
    "semantic": {
      "success": {
        "fg":     { "value": "#0E8C56", "description": "흰 배경 위 AA 통과 (기존 #12B26B는 텍스트로 쓰면 약함)." },
        "bg":     { "value": "#E6F8EF" },
        "border": { "value": "#A5E5C4" }
      },
      "warning": {
        "fg":      { "value": "#B7791F", "description": "텍스트 색. #F59E0B는 텍스트 금지." },
        "bg":      { "value": "#FFF7E6" },
        "cta-bg":  { "value": "#D97706", "description": "★ 흰 글자 위 AA 통과. 기존 #F59E0B + 흰글자(2.6:1) 대체." },
        "border":  { "value": "#F2C879" }
      },
      "danger": {
        "fg":     { "value": "#C03B3F" },
        "bg":     { "value": "#FDECEC" },
        "border": { "value": "#F0A8AB" }
      },
      "live": {
        "fg": { "value": "#E5484D" },
        "bg": { "value": "#FFE9EA" }
      }
    },
    "chart": {
      "1": { "value": "#2854D8" },
      "2": { "value": "#0E8C56" },
      "3": { "value": "#D97706" },
      "4": { "value": "#8B5CF6" },
      "5": { "value": "#06B6D4" },
      "6": { "value": "#E5484D" }
    }
  },
  "font": {
    "sans": { "value": "\"Pretendard Variable\", Pretendard, -apple-system, system-ui, Roboto, sans-serif" },
    "mono": { "value": "\"Geist Mono\", ui-monospace, SFMono-Regular, Menlo, monospace" }
  },
  "fontWeight": {
    "regular":  { "value": 400 },
    "medium":   { "value": 500 },
    "semibold": { "value": 600 },
    "bold":     { "value": 700 }
  },
  "fontSize": {
    "caption":   { "value": "12px", "lineHeight": "16px", "weight": 500 },
    "body":      { "value": "14px", "lineHeight": "22px", "weight": 400, "description": "모바일 본문." },
    "bodyLg":    { "value": "16px", "lineHeight": "24px", "weight": 400, "description": "★ 데스크탑 본문." },
    "title3":    { "value": "18px", "lineHeight": "26px", "weight": 600 },
    "title2":    { "value": "20px", "lineHeight": "28px", "weight": 600 },
    "title1":    { "value": "24px", "lineHeight": "32px", "weight": 700 },
    "display2":  { "value": "28px", "lineHeight": "36px", "weight": 700 },
    "display1":  { "value": "32px", "lineHeight": "40px", "weight": 700 }
  },
  "forbidden": {
    "fontSizeBelow12px":   true,
    "fontSize12_5px":      true,
    "fontWeightUnder500ForMeta": true,
    "amberTextOnAmberBg":  true,
    "borderRadius16or18or26": true
  },
  "spacing": {
    "0":  { "value": "0px" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" }
  },
  "radius": {
    "sm":   { "value": "8px",    "description": "작은 chip, input." },
    "md":   { "value": "14px",   "description": "★ 카드/버튼/인풋 표준." },
    "lg":   { "value": "20px",   "description": "히어로, 큰 컨테이너." },
    "pill": { "value": "9999px", "description": "아바타, FAB, status chip." }
  },
  "elevation": {
    "0":   { "value": "none" },
    "1":   { "value": "0 1px 2px rgba(18,22,39,0.04)" },
    "2":   { "value": "0 4px 12px rgba(18,22,39,0.06), 0 2px 4px rgba(18,22,39,0.04)" },
    "3":   { "value": "0 12px 24px rgba(18,22,39,0.08), 0 4px 8px rgba(18,22,39,0.04)" },
    "fab": { "value": "0 10px 15px -3px rgba(40,84,216,0.30), 0 4px 6px -4px rgba(40,84,216,0.30)" }
  },
  "focusRing": {
    "default": { "value": "0 0 0 3px rgba(59,111,246,0.35)" },
    "danger":  { "value": "0 0 0 3px rgba(229,72,77,0.30)" }
  },
  "motion": {
    "duration": {
      "fast": { "value": "120ms" },
      "base": { "value": "200ms" },
      "slow": { "value": "320ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
      "emphasis": { "value": "cubic-bezier(0.2, 0.8, 0.2, 1)" }
    }
  },
  "breakpoint": {
    "sm":  { "value": "640px" },
    "md":  { "value": "768px" },
    "lg":  { "value": "1024px", "description": "★ 사이드바 ↔ 하단 탭바 분기점." },
    "xl":  { "value": "1280px" },
    "2xl": { "value": "1536px" }
  },
  "layout": {
    "header": {
      "height-desktop": { "value": "56px" },
      "height-mobile":  { "value": "52px" }
    },
    "sidebar": {
      "width": { "value": "240px" }
    },
    "tabBar": {
      "height": { "value": "64px" }
    },
    "content": {
      "maxWidth":      { "value": "1280px" },
      "gutter-desktop":{ "value": "24px" },
      "gutter-mobile": { "value": "16px" }
    },
    "fab": {
      "offset-bottom":  { "value": "calc(64px + 24px)", "description": "탭바 + 24 마진. 채팅 화면에서는 숨김." },
      "size":           { "value": "56px" }
    },
    "hitArea": {
      "min": { "value": "44px", "description": "터치 타깃 최소. 작은 시각 뱃지도 padding으로 보강." }
    }
  },
  "component": {
    "button": {
      "minHeight-desktop": { "value": "40px" },
      "minHeight-mobile":  { "value": "44px" },
      "radius":            { "value": "14px" },
      "fontWeight":        { "value": 600 }
    },
    "card": {
      "radius":              { "value": "14px" },
      "radiusLarge":         { "value": "20px" },
      "padding-desktop":     { "value": "20px" },
      "padding-mobile":      { "value": "16px" },
      "border":              { "value": "1px solid {color.border.default}" },
      "background":          { "value": "{color.surface.default}" }
    },
    "chip": {
      "radius":     { "value": "9999px" },
      "fontSize":   { "value": "12px" },
      "fontWeight": { "value": 600 },
      "height":     { "value": "24px" }
    },
    "hero": {
      "background": { "value": "linear-gradient(135deg, #2854D8 0%, #3B6FF6 100%)" },
      "radius":     { "value": "20px" },
      "padding":    { "value": "24px 32px" },
      "textColor":  { "value": "#FFFFFF" }
    },
    "chat": {
      "bubble-user-bg":      { "value": "{color.brand.50}" },
      "bubble-user-text":    { "value": "{color.brand.700}" },
      "bubble-bot-bg":       { "value": "{color.surface.default}" },
      "bubble-bot-border":   { "value": "1px solid {color.border.default}" },
      "bubble-bot-text":     { "value": "{color.text.primary}" },
      "typingIndicator":     { "value": "3-dot bounce 1.4s loop" },
      "messageEnter":        { "value": "fade-up 8→0px 200ms ease-out" }
    },
    "fab": {
      "background": { "value": "{color.brand.600}" },
      "size":       { "value": "56px" },
      "radius":     { "value": "9999px" },
      "shadow":     { "value": "{elevation.fab}" }
    }
  },
  "a11y": {
    "contrast": {
      "bodyText":  { "value": "4.5:1", "description": "본문(<18px or <14pt bold) 최소." },
      "largeText": { "value": "3:1", "description": "18px+/14pt+ bold." }
    },
    "focusVisible": { "value": "{focusRing.default}" },
    "hitArea":      { "value": "{layout.hitArea.min}" }
  }
}
