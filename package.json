{
  "name": "pullim-classbot-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:classbot": "bun --filter @pullim-classbot/classbot dev",
    "dev:backend": "bun --filter @pullim-classbot/backend dev",
    "build": "turbo build",
    "build:classbot": "bun --filter @pullim-classbot/classbot build",
    "build:backend": "bun --filter @pullim-classbot/backend build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && rm -rf .docker/postgres && docker compose up -d postgres"
  },
  "devDependencies": {
    "turbo": "^2.7.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "bun@1.3.12"
}
